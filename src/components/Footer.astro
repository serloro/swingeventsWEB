---
const year = new Date().getFullYear();
---

<footer>
  <div class="footer-grid">
    <div class="footer-brand">
      <div class="footer-name">Swing <em>Festivals</em></div>
      <p class="footer-tag">The go-to directory to find swing festivals worldwide.</p>
    </div>
    <div class="footer-col">
      <h4>Explore</h4>
      <a href="#eventos">Event calendar</a>
      <a href="#">Featured festivals</a>
    </div>
    <div class="footer-col">
      <h4>Community</h4>
      <a href="#blog">News</a>
      <a href="#">Newsletter</a>
      <a href="/contact">Contact</a>
    </div>
  </div>
  <div class="footer-bottom">
    <span>© {year} <b>Swing Festivals</b> · The world swing directory</span>
    <span>Made with ♪ for the swing community</span>
  </div>
</footer>

<style>
  footer {
    background: var(--dark);
    border-top: 1px solid rgba(201,168,76,.12);
    padding: 38px 5vw 26px;
  }
  .footer-grid {
    display: grid; grid-template-columns: 1.2fr 1fr 1fr;
    gap: 36px; margin-bottom: 28px;
  }
  .footer-name { font-family: Georgia, serif; font-size: 1.25rem; color: var(--cream); margin-bottom: 7px; }
  .footer-name em { color: var(--gold); font-style: italic; }
  .footer-tag  { font-size: 12px; color: var(--muted); font-style: italic; line-height: 1.6; }
  .footer-col h4 {
    font-family: Arial, sans-serif; font-size: 9px; letter-spacing: .3em;
    text-transform: uppercase; color: var(--gold); margin-bottom: 13px;
  }
  .footer-col a {
    display: block; font-family: Arial, sans-serif; font-size: 12px;
    color: var(--muted); margin-bottom: 8px; transition: color .2s;
  }
  .footer-col a:hover { color: var(--cream); }
  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,.06); padding-top: 18px;
    display: flex; justify-content: space-between; flex-wrap: wrap; gap: 8px;
    font-family: Arial, sans-serif; font-size: 10px; color: var(--muted); letter-spacing: .07em;
  }
  .footer-bottom b { color: var(--gold); }
</style>
