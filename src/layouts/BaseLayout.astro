---
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
}
const {
  title       = 'Swing Festivals — Descubre los mejores festivales de swing',
  description = 'El directorio de referencia para encontrar festivales de swing, Lindy Hop, Balboa y jazz en todo el mundo.',
} = Astro.props;
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <ViewTransitions />

  <style is:global>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    :root {
      --gold: #C9A84C; --gold-l: #E8C97A;
      --teal-l: #3A9A86;
      --dark: #0D0A07; --dark2: #111009; --dark3: #1A1510;
      --cream: #F0E6C8; --cream2: #D4C49A; --muted: #8A7A5A;
    }
    html  { scroll-behavior: smooth; scroll-padding-top: 80px; }
    body  { background: var(--dark); color: var(--cream); font-family: Georgia, serif; overflow-x: hidden; }
    ::-webkit-scrollbar       { width: 5px; }
    ::-webkit-scrollbar-track { background: var(--dark); }
    ::-webkit-scrollbar-thumb { background: var(--teal-l); }
    a { text-decoration: none; }

    /* Reveal scroll animations */
    .reveal {
      opacity: 0;
      transform: translateY(22px);
      transition: opacity .7s ease, transform .7s ease;
      transition-delay: var(--rd, 0s);
    }
    .reveal.visible { opacity: 1; transform: none; }

    /* ── View Transitions ─────────────────────────────────── */
    @keyframes vt-in  { from { opacity: 0; transform: translateY(18px); } }
    @keyframes vt-out { to   { opacity: 0; transform: translateY(-8px); } }

    ::view-transition-old(root) { animation: 0.22s ease-out vt-out; }
    ::view-transition-new(root) { animation: 0.34s ease-out vt-in backwards; }

    /* Elementos compartidos entre páginas: solo fade+scale suave */
    ::view-transition-old(shared) {
      animation: 0.25s ease-out both fade-scale-out;
    }
    ::view-transition-new(shared) {
      animation: 0.35s ease-out both fade-scale-in;
    }
    @keyframes fade-scale-out {
      from { opacity: 1; transform: scale(1); }
      to   { opacity: 0; transform: scale(0.97); }
    }
    @keyframes fade-scale-in {
      from { opacity: 0; transform: scale(1.03); }
      to   { opacity: 1; transform: scale(1); }
    }
  </style>
</head>
<body>
  <slot />
  <script>
    function setupReveal() {
      const io = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            (e.target as HTMLElement).classList.add('visible');
            io.unobserve(e.target);
          }
        });
      }, { threshold: 0.1, rootMargin: '-10px 0px' });

      document.querySelectorAll('.reveal:not(.visible)').forEach(el => io.observe(el));

      const reObserve = () =>
        document.querySelectorAll('.reveal:not(.visible)').forEach(el => io.observe(el));
      document.addEventListener('events-rendered', reObserve);
    }

    // astro:page-load dispara en carga inicial y en cada navegación con ViewTransitions
    document.addEventListener('astro:page-load', setupReveal);
  </script>
</body>
</html>
