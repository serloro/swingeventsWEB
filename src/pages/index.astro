---
import BaseLayout     from '../layouts/BaseLayout.astro';
import Nav            from '../components/Nav.astro';
import Hero           from '../components/Hero.astro';
import EventCalendar  from '../components/EventCalendar.astro';
import BlogGrid       from '../components/BlogGrid.astro';
import Footer         from '../components/Footer.astro';

import { getEvents, getPosts } from '../lib/directus.js';

// Carga datos — si Directus no está configurado usa los mock automáticamente
const [events, posts] = await Promise.all([getEvents(), getPosts()]);
---

<BaseLayout>
  <Nav />
  <Hero />

  <div class="below-hero">
    <!-- Divider hero → eventos -->
    <div class="divider" style="background:linear-gradient(var(--dark),var(--dark2));">
      <svg viewBox="0 0 1440 88" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,44 C360,88 720,0 1080,44 C1260,66 1380,34 1440,44 L1440,88 L0,88Z" style="fill:var(--dark2)" opacity=".65"/>
        <path d="M0,60 C200,24 500,80 800,52 C1050,30 1300,70 1440,56 L1440,88 L0,88Z" style="fill:var(--dark2)"/>
      </svg>
    </div>

    <EventCalendar events={events} />

    <!-- Divider eventos → blog -->
    <div class="divider" style="background:linear-gradient(var(--dark2),var(--dark));">
      <svg viewBox="0 0 1440 88" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,36 C300,88 600,6 900,48 C1100,74 1300,20 1440,40 L1440,0 L0,0Z" style="fill:var(--dark)"/>
        <path d="M0,16 C400,68 700,2 1000,40 C1150,60 1350,10 1440,26 L1440,0 L0,0Z" style="fill:var(--dark)" opacity=".5"/>
      </svg>
    </div>

    <BlogGrid posts={posts} />
    <Footer />
  </div>
</BaseLayout>

<style>
  .below-hero {
    position: relative;
  }
  .divider {
    height: 88px; position: relative; overflow: hidden;
  }
  .divider svg {
    width: 100%; height: 100%;
    position: absolute; top: 0; left: 0;
  }
</style>
