---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav        from '../components/Nav.astro';
import Footer     from '../components/Footer.astro';
---

<BaseLayout
  title="About us — Swing Festivals"
  description="We are a directory created by swing enthusiasts for the global swing community. Discover our story and mission."
>
  <Nav />

  <div class="about-page">

    <!-- Hero -->
    <header class="about-hero">
      <div class="about-hero-glow"></div>
      <div class="about-hero-inner">
        <div class="eyebrow reveal">About us</div>
        <h1 class="about-title reveal" style="--rd:.08s">
          Built by <em>dancers</em>,<br/>for the swing community
        </h1>
        <p class="about-lead reveal" style="--rd:.16s">
          Swing Festivals was born from a simple question: where can I find
          all the swing festivals in the world in one place? We couldn't find
          an answer, so we built it ourselves.
        </p>
      </div>
      <div class="about-hero-note reveal" style="--rd:.24s">
        <span class="note-icon">♪</span>
        <span>A community project, for the community</span>
      </div>
    </header>

    <!-- Our story -->
    <section class="about-section bg-dark2">
      <div class="about-inner">
        <div class="two-col">
          <div class="col-text">
            <div class="eyebrow reveal">Our story</div>
            <h2 class="section-title reveal" style="--rd:.08s">From dancers to builders</h2>
            <p class="body-text reveal" style="--rd:.14s">
              It all started on a dance floor. Like most swing enthusiasts,
              we spent hours hunting for festivals across Facebook groups,
              scattered mailing lists and outdated websites. We kept missing
              incredible events simply because the information wasn't in one place.
            </p>
            <p class="body-text reveal" style="--rd:.2s">
              In 2024 we decided to do something about it. We combined our passion
              for Lindy Hop, Balboa and jazz with the desire to build a useful tool
              for the whole community. That's how Swing Festivals was born.
            </p>
          </div>
          <div class="col-deco reveal" style="--rd:.1s">
            <div class="deco-card">
              <div class="deco-year">2024</div>
              <div class="deco-label">Founded</div>
              <div class="deco-sep"></div>
              <div class="deco-stat-row">
                <div>
                  <div class="deco-num">30+</div>
                  <div class="deco-sub">countries</div>
                </div>
                <div>
                  <div class="deco-num">∞</div>
                  <div class="deco-sub">swing steps</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Mission -->
    <section class="about-section bg-dark">
      <div class="about-inner">
        <div class="eyebrow reveal center">Our mission</div>
        <h2 class="section-title reveal center" style="--rd:.08s">Connecting the global swing community</h2>
        <p class="body-text center reveal" style="--rd:.14s">
          Swing has no borders. From Buenos Aires to Tokyo, from Stockholm
          to Mexico City, dancers around the world share the same passion
          for rhythm, improvisation and connection.
        </p>

        <div class="pillars">
          <div class="pillar reveal" style="--rd:.1s">
            <div class="pillar-icon">◎</div>
            <h3 class="pillar-title">Visibility</h3>
            <p class="pillar-text">
              We shine a light on festivals of all sizes: from large international
              events to small local exchanges that deserve to be discovered.
            </p>
          </div>
          <div class="pillar reveal" style="--rd:.17s">
            <div class="pillar-icon">◈</div>
            <h3 class="pillar-title">Community</h3>
            <p class="pillar-text">
              We believe every dancer, teacher, band and DJ is part of a unique
              cultural fabric. Our mission is to keep that fabric connected and alive.
            </p>
          </div>
          <div class="pillar reveal" style="--rd:.24s">
            <div class="pillar-icon">♪</div>
            <h3 class="pillar-title">Accessibility</h3>
            <p class="pillar-text">
              Information should be free and easy to find. No paywalls, no
              mandatory sign-ups. An open resource for the entire swing scene.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- The scene -->
    <section class="about-section bg-dark2">
      <div class="about-inner">
        <div class="two-col two-col--rev">
          <div class="col-deco reveal" style="--rd:.06s">
            <div class="quote-card">
              <div class="quote-mark">"</div>
              <p class="quote-text">
                Swing is more than a dance. It's a way of being in the world:
                present, connected, improvising with whoever is in front of you.
              </p>
              <div class="quote-attr">— Swing community, worldwide</div>
            </div>
          </div>
          <div class="col-text">
            <div class="eyebrow reveal">The scene</div>
            <h2 class="section-title reveal" style="--rd:.08s">A global family</h2>
            <p class="body-text reveal" style="--rd:.14s">
              Swing enthusiasts form a peculiar and wonderful community.
              We travel thousands of miles to dance with strangers who become
              friends. We learn languages for the sake of festivals. We organise
              exchanges in neighbourhood halls.
            </p>
            <p class="body-text reveal" style="--rd:.2s">
              Lindy Hop, Balboa, Charleston, Blues, Collegiate Shag… each style
              has its own character, but all share the same spirit:
              music as a universal language and the body as an instrument of dialogue.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="about-cta">
      <div class="about-inner">
        <div class="cta-inner reveal">
          <div class="eyebrow center">Running a festival?</div>
          <h2 class="cta-title">Add your event to the directory</h2>
          <p class="cta-sub">
            If you organise a swing festival, workshop, social or exchange and
            want it listed in the directory, get in touch. It's free and reaches
            the whole community.
          </p>
          <a href="mailto:hello@swingfestivals.com" class="cta-btn">Contact us</a>
        </div>
      </div>
    </section>

  </div>

  <Footer />
</BaseLayout>

<style>
  .about-page { padding-top: 66px; }

  /* ── Hero ── */
  .about-hero {
    position: relative; overflow: hidden;
    padding: 90px 5vw 80px;
    background: radial-gradient(ellipse 90% 80% at 20% 110%, rgba(58,154,134,.08) 0%, transparent 65%), var(--dark);
  }
  .about-hero-glow {
    position: absolute; inset: 0; pointer-events: none;
    background:
      radial-gradient(circle 500px at 5% 100%, rgba(58,154,134,.06) 0%, transparent 70%),
      radial-gradient(circle 400px at 95% 0%, rgba(201,168,76,.05) 0%, transparent 70%);
  }
  .about-hero-inner {
    max-width: 820px; margin: 0 auto; text-align: center;
    position: relative; z-index: 1;
  }
  .about-title {
    font-family: Georgia, serif;
    font-size: clamp(2.2rem, 6vw, 4.2rem);
    color: var(--cream); line-height: 1.1; margin: 1rem 0 1.4rem;
  }
  .about-title em { color: var(--gold); font-style: italic; }
  .about-lead {
    font-family: Georgia, serif; font-size: clamp(1rem, 2vw, 1.2rem);
    color: var(--cream2); line-height: 1.8; max-width: 640px; margin: 0 auto;
  }
  .about-hero-note {
    display: flex; align-items: center; justify-content: center; gap: 10px;
    margin-top: 3rem; position: relative; z-index: 1;
    font-family: Arial, sans-serif; font-size: 10px;
    letter-spacing: .28em; text-transform: uppercase; color: var(--muted);
  }
  .note-icon { color: var(--gold); font-size: 1rem; }

  /* ── Sections ── */
  .about-section { padding: 80px 5vw; }
  .bg-dark  { background: var(--dark); }
  .bg-dark2 { background: var(--dark2); }
  .about-inner { max-width: 960px; margin: 0 auto; }

  .eyebrow {
    display: inline-flex; align-items: center; gap: 10px;
    font-family: Arial, sans-serif; font-size: 9.5px;
    letter-spacing: .36em; text-transform: uppercase;
    color: var(--gold); font-weight: 700; margin-bottom: .8rem;
  }
  .eyebrow::after { content: ''; width: 26px; height: 1px; background: var(--gold); opacity: .4; }
  .eyebrow.center { display: flex; justify-content: center; }

  .section-title {
    font-family: Georgia, serif;
    font-size: clamp(1.7rem, 3.5vw, 2.6rem);
    color: var(--cream); line-height: 1.15; margin-bottom: 1.4rem;
  }
  .section-title.center { text-align: center; }

  .body-text {
    font-family: Georgia, serif; font-size: 1.05rem;
    color: var(--cream2); line-height: 1.85; margin-bottom: 1.1rem;
  }
  .body-text.center { text-align: center; max-width: 680px; margin-left: auto; margin-right: auto; }

  /* ── Two col layout ── */
  .two-col {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 64px; align-items: center;
  }
  .two-col--rev .col-deco { order: -1; }

  @media (max-width: 760px) {
    .two-col { grid-template-columns: 1fr; gap: 40px; }
    .two-col--rev .col-deco { order: 0; }
  }

  /* ── Deco card ── */
  .deco-card {
    background: rgba(201,168,76,.05); border: 1px solid rgba(201,168,76,.15);
    padding: 36px 32px; position: relative;
  }
  .deco-card::before {
    content: ''; position: absolute; top: 10px; left: 10px; right: 10px; bottom: 10px;
    border: 1px solid rgba(201,168,76,.07); pointer-events: none;
  }
  .deco-year {
    font-family: Georgia, serif; font-size: 4.5rem;
    color: var(--gold); opacity: .18; line-height: 1; margin-bottom: .6rem;
    letter-spacing: -.04em;
  }
  .deco-label {
    font-family: Arial, sans-serif; font-size: 9px;
    letter-spacing: .3em; text-transform: uppercase; color: var(--muted);
    margin-bottom: 1.6rem;
  }
  .deco-sep { height: 1px; background: rgba(201,168,76,.15); margin-bottom: 1.6rem; }
  .deco-stat-row {
    display: flex; gap: 36px;
  }
  .deco-num {
    font-family: Georgia, serif; font-size: 2.2rem; color: var(--teal-l); line-height: 1;
  }
  .deco-sub {
    font-family: Arial, sans-serif; font-size: 9px;
    letter-spacing: .22em; text-transform: uppercase; color: var(--muted); margin-top: 4px;
  }

  /* ── Quote card ── */
  .quote-card {
    background: rgba(58,154,134,.05); border-left: 3px solid var(--teal-l);
    padding: 36px 32px;
  }
  .quote-mark {
    font-family: Georgia, serif; font-size: 5rem; color: var(--teal-l);
    opacity: .3; line-height: .8; margin-bottom: .6rem;
  }
  .quote-text {
    font-family: Georgia, serif; font-size: 1.1rem;
    color: var(--cream2); line-height: 1.8; font-style: italic; margin-bottom: 1.2rem;
  }
  .quote-attr {
    font-family: Arial, sans-serif; font-size: 10px;
    letter-spacing: .2em; text-transform: uppercase; color: var(--muted);
  }

  /* ── Pillars ── */
  .pillars {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 28px; margin-top: 3.2rem;
  }
  @media (max-width: 720px) {
    .pillars { grid-template-columns: 1fr; }
  }
  .pillar {
    background: rgba(255,255,255,.02); border: 1px solid rgba(255,255,255,.06);
    padding: 32px 28px; transition: border-color .25s, background .25s;
  }
  .pillar:hover {
    border-color: rgba(201,168,76,.25); background: rgba(201,168,76,.03);
  }
  .pillar-icon {
    font-size: 1.4rem; color: var(--gold); margin-bottom: 1rem; display: block;
  }
  .pillar-title {
    font-family: Georgia, serif; font-size: 1.15rem;
    color: var(--cream); margin-bottom: .7rem;
  }
  .pillar-text {
    font-family: Arial, sans-serif; font-size: 12.5px;
    color: var(--muted); line-height: 1.75;
  }

  /* ── CTA ── */
  .about-cta {
    padding: 90px 5vw;
    background: radial-gradient(ellipse 70% 80% at 50% 100%, rgba(201,168,76,.05) 0%, transparent 70%), var(--dark);
    border-top: 1px solid rgba(201,168,76,.1);
  }
  .cta-inner { text-align: center; max-width: 640px; margin: 0 auto; }
  .cta-title {
    font-family: Georgia, serif; font-size: clamp(1.8rem, 4vw, 2.8rem);
    color: var(--cream); margin: .8rem 0 1.2rem; line-height: 1.2;
  }
  .cta-sub {
    font-family: Arial, sans-serif; font-size: 13px;
    color: var(--muted); line-height: 1.8; margin-bottom: 2.2rem;
  }
  .cta-btn {
    display: inline-block;
    background: var(--gold); color: var(--dark);
    font-family: Arial, sans-serif; font-size: 10px;
    letter-spacing: .22em; text-transform: uppercase; font-weight: 700;
    padding: 14px 32px; transition: background .2s, transform .2s;
  }
  .cta-btn:hover { background: var(--gold-l); transform: translateY(-2px); }
</style>
