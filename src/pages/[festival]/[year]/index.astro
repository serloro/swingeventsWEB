---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Nav       from '../../../components/Nav.astro';
import Footer    from '../../../components/Footer.astro';
import { getEvents, slugify } from '../../../lib/directus.js';
import type { Event, Artist } from '../../../types/index.js';

export async function getStaticPaths() {
  const events = await getEvents();
  return events
    .filter(e => e.type === 'festival')
    .map(event => ({
      params: {
        festival: slugify(event.name),
        year:     String(new Date(event.date).getFullYear()),
      },
      props: { event },
    }));
}

interface Props { event: Event }
const { event } = Astro.props;

const MONTH_NAMES = ['January','February','March','April','May','June',
                     'July','August','September','October','November','December'];

function fmtFullDate(iso: string) {
  const d = new Date(iso);
  return `${MONTH_NAMES[d.getMonth()]} ${d.getDate()}, ${d.getFullYear()}`;
}

function fmtDateRange(from: string, to?: string) {
  const a = new Date(from);
  if (!to) return fmtFullDate(from);
  const b = new Date(to);
  if (a.getMonth() === b.getMonth() && a.getFullYear() === b.getFullYear()) {
    return `${MONTH_NAMES[a.getMonth()]} ${a.getDate()}–${b.getDate()}, ${a.getFullYear()}`;
  }
  return `${MONTH_NAMES[a.getMonth()]} ${a.getDate()} – ${MONTH_NAMES[b.getMonth()]} ${b.getDate()}, ${b.getFullYear()}`;
}

const teachers = event.artists?.filter(a => a.role === 'teacher') ?? [];
const bands    = event.artists?.filter(a => a.role === 'band' || a.role === 'dj') ?? [];

// Iniciales para el avatar
function initials(name: string): string {
  return name.split(' ').slice(0, 2).map(w => w[0]).join('').toUpperCase();
}

const TAG_COLORS: Record<string, string> = {
  festival: '#9A9A18', social: '#3A9A86',
  workshop: '#9A2090', competicion: '#9A2020', exchange: '#209A7A',
};
---

<BaseLayout
  title={`${event.name} ${new Date(event.date).getFullYear()} — Swing Festivals`}
  description={event.description ?? `${event.name} en ${event.city}, ${event.country}.`}
>
  <Nav />

  <div class="festival-page">

    <!-- Hero -->
    <header class="fhero">
      {event.image && (
        <img src={event.image} alt={event.name} class="fhero-img" />
      )}
      <div class="fhero-overlay"></div>
      <div class="fhero-bg-glow"></div>

      <a href="/#eventos" class="back-link reveal">← Back to calendar</a>

      <div class="fhero-badges reveal" style="--rd:.05s">
        <span class="badge-type" style={`color:${TAG_COLORS[event.type]};border-color:${TAG_COLORS[event.type]}`}>
          {event.type}
        </span>
        <span class="badge-style">{event.style}</span>
      </div>

      <h1 class="fhero-name reveal" style="--rd:.1s" transition:name={`festival-${event.id}`}>
        {event.name}
      </h1>

      <div class="fhero-date reveal" style="--rd:.15s">
        <span class="fhero-date-num">
          {new Date(event.date).getDate()}
          {event.dateTo && new Date(event.dateTo).getDate() !== new Date(event.date).getDate() && (
            <>–{new Date(event.dateTo).getDate()}</>
          )}
        </span>
        <div class="fhero-date-info">
          <span class="fhero-month">
            {MONTH_NAMES[new Date(event.date).getMonth()].toUpperCase()}
            {event.dateTo && new Date(event.dateTo).getMonth() !== new Date(event.date).getMonth() && (
              <> – {MONTH_NAMES[new Date(event.dateTo).getMonth()].toUpperCase()}</>
            )}
          </span>
          <span class="fhero-year">{new Date(event.date).getFullYear()}</span>
        </div>
      </div>

      <p class="fhero-loc reveal" style="--rd:.2s">
        <span class="loc-icon">◈</span>
        {event.city}, {event.country}
        <span class="loc-sep">·</span>
        {event.continent}
      </p>

      <div class="fhero-actions reveal" style="--rd:.25s">
        {event.ticketUrl && (
          <a href={event.ticketUrl} target="_blank" rel="noopener" class="btn-tickets">
            Tickets →
          </a>
        )}
        {event.url && (
          <a href={event.url} target="_blank" rel="noopener" class="btn-web">
            Official website
          </a>
        )}
        <button class="btn-cal" id="add-to-cal">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          Add to calendar
        </button>
      </div>
    </header>

    <!-- Descripción -->
    {event.description && (
      <section class="fdesc">
        <div class="fdesc-inner reveal">
          <div class="sec-eyebrow">About the festival</div>
          <p class="fdesc-text">{event.description}</p>
        </div>
      </section>
    )}

    <!-- Artistas -->
    {(teachers.length > 0 || bands.length > 0) && (
      <section class="fartists">
        <div class="fartists-inner">

          <div class="sec-header reveal">
            <div class="sec-eyebrow">Lineup</div>
            <h2 class="sec-title">Artists</h2>
          </div>

          {teachers.length > 0 && (
            <div class="artists-group reveal" style="--rd:.1s">
              <h3 class="artists-group-title">
                <span class="artists-group-icon">◈</span> Teachers
              </h3>
              <div class="artists-grid">
                {teachers.map((artist, i) => (
                  <a
                    href={`/artista/${artist.slug}`}
                    class="artist-card reveal"
                    style={`--rd:${0.1 + i * 0.08}s`}
                    transition:name={`artist-card-${artist.slug}`}
                  >
                    <div class="artist-avatar artist-avatar--teacher">
                      {artist.image
                        ? <img src={artist.image} alt={artist.name} class="avatar-img" />
                        : initials(artist.name)
                      }
                    </div>
                    <div class="artist-info">
                      <span class="artist-name" transition:name={`artist-name-${artist.slug}`}>
                        {artist.name}
                      </span>
                      {artist.nationality && (
                        <span class="artist-nat">{artist.nationality}</span>
                      )}
                      {artist.bio && (
                        <span class="artist-bio">{artist.bio.length > 90 ? artist.bio.slice(0, 90).trimEnd() + '…' : artist.bio}</span>
                      )}
                      {artist.specialties && (
                        <div class="artist-tags">
                          {artist.specialties.slice(0, 2).map(s => (
                            <span class="artist-tag">{s}</span>
                          ))}
                        </div>
                      )}
                    </div>
                    <span class="artist-arrow">→</span>
                  </a>
                ))}
              </div>
            </div>
          )}

          {bands.length > 0 && (
            <div class="artists-group reveal" style={`--rd:${0.1 + teachers.length * 0.05}s`}>
              <h3 class="artists-group-title">
                <span class="artists-group-icon">♪</span> Bands
              </h3>
              <div class="artists-grid">
                {bands.map((artist, i) => (
                  <a
                    href={`/artista/${artist.slug}`}
                    class="artist-card reveal"
                    style={`--rd:${0.15 + i * 0.08}s`}
                    transition:name={`artist-card-${artist.slug}`}
                  >
                    <div class="artist-avatar artist-avatar--band">
                      {artist.image
                        ? <img src={artist.image} alt={artist.name} class="avatar-img" />
                        : '♪'
                      }
                    </div>
                    <div class="artist-info">
                      <span class="artist-name" transition:name={`artist-name-${artist.slug}`}>
                        {artist.name}
                      </span>
                      {artist.nationality && (
                        <span class="artist-nat">{artist.nationality}</span>
                      )}
                      {artist.bio && (
                        <span class="artist-bio">{artist.bio.length > 90 ? artist.bio.slice(0, 90).trimEnd() + '…' : artist.bio}</span>
                      )}
                      {artist.specialties && (
                        <div class="artist-tags">
                          {artist.specialties.slice(0, 2).map(s => (
                            <span class="artist-tag">{s}</span>
                          ))}
                        </div>
                      )}
                    </div>
                    <span class="artist-arrow">→</span>
                  </a>
                ))}
              </div>
            </div>
          )}

        </div>
      </section>
    )}

    <!-- Info extra -->
    <section class="finfo">
      <div class="finfo-inner reveal">
        <div class="finfo-row">
          <div class="finfo-item">
            <span class="finfo-label">Style</span>
            <span class="finfo-val">{event.style}</span>
          </div>
          <div class="finfo-item">
            <span class="finfo-label">Date</span>
            <span class="finfo-val">{fmtDateRange(event.date, event.dateTo)}</span>
          </div>
          <div class="finfo-item">
            <span class="finfo-label">Venue</span>
            <span class="finfo-val">{event.city}, {event.country}</span>
          </div>
          {event.ticketUrl && (
            <div class="finfo-item">
              <span class="finfo-label">Tickets</span>
              <a href={event.ticketUrl} target="_blank" rel="noopener" class="finfo-link">
                Buy tickets →
              </a>
            </div>
          )}
        </div>
      </div>
    </section>

    <!-- Redes sociales -->
    {(event.instagram || event.facebook || event.youtube || event.url) && (
      <section class="fsocial">
        <div class="fsocial-inner reveal">
          <div class="sec-eyebrow">Follow us</div>
          <div class="fsocial-links">
            {event.instagram && (
              <a
                href={event.instagram.startsWith('http') ? event.instagram : `https://instagram.com/${event.instagram.replace(/^@/, '')}`}
                target="_blank" rel="noopener"
                class="fsocial-item"
              >
                <span class="fsocial-icon">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/>
                    <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
                  </svg>
                </span>
                <div>
                  <span class="fsocial-label">Instagram</span>
                  <span class="fsocial-val">{event.instagram.startsWith('http') ? 'View profile' : event.instagram}</span>
                </div>
                <span class="fsocial-arrow">→</span>
              </a>
            )}
            {event.facebook && (
              <a
                href={event.facebook.startsWith('http') ? event.facebook : `https://facebook.com/${event.facebook}`}
                target="_blank" rel="noopener"
                class="fsocial-item"
              >
                <span class="fsocial-icon">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
                  </svg>
                </span>
                <div>
                  <span class="fsocial-label">Facebook</span>
                  <span class="fsocial-val">{event.facebook.startsWith('http') ? 'View page' : event.facebook}</span>
                </div>
                <span class="fsocial-arrow">→</span>
              </a>
            )}
            {event.youtube && (
              <a
                href={event.youtube.startsWith('http') ? event.youtube : `https://youtube.com/@${event.youtube.replace(/^@/, '')}`}
                target="_blank" rel="noopener"
                class="fsocial-item"
              >
                <span class="fsocial-icon">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/>
                    <polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="currentColor" stroke="none"/>
                  </svg>
                </span>
                <div>
                  <span class="fsocial-label">YouTube</span>
                  <span class="fsocial-val">{event.youtube.startsWith('http') ? 'View channel' : event.youtube}</span>
                </div>
                <span class="fsocial-arrow">→</span>
              </a>
            )}
            {event.url && (
              <a href={event.url} target="_blank" rel="noopener" class="fsocial-item">
                <span class="fsocial-icon">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="2" y1="12" x2="22" y2="12"/>
                    <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                  </svg>
                </span>
                <div>
                  <span class="fsocial-label">Official website</span>
                  <span class="fsocial-val">Visit →</span>
                </div>
                <span class="fsocial-arrow">→</span>
              </a>
            )}
          </div>
        </div>
      </section>
    )}

    <!-- Mapa del venue -->
    {event.map && (
      <section class="fmap">
        <div class="fmap-inner reveal">
          <div class="sec-eyebrow">Venue</div>
          <h2 class="sec-title fmap-title">Location</h2>
          <div class="fmap-wrap">
            <iframe
              title={`Map of ${event.name}`}
              src={`https://www.openstreetmap.org/export/embed.html?bbox=${event.map.lng - 0.02},${event.map.lat - 0.014},${event.map.lng + 0.02},${event.map.lat + 0.014}&layer=mapnik&marker=${event.map.lat},${event.map.lng}`}
              loading="lazy"
              referrerpolicy="no-referrer"
              class="fmap-iframe"
            ></iframe>
          </div>
          <a
            href={`https://www.openstreetmap.org/?mlat=${event.map.lat}&mlon=${event.map.lng}#map=15/${event.map.lat}/${event.map.lng}`}
            target="_blank"
            rel="noopener noreferrer"
            class="fmap-link"
          >
            Open in OpenStreetMap →
          </a>
        </div>
      </section>
    )}

  </div>

  <Footer />
</BaseLayout>

<script define:vars={{
  _name:    event.name,
  _date:    event.date,
  _dateTo:  event.dateTo ?? null,
  _city:    event.city,
  _country: event.country,
  _desc:    event.description ?? '',
  _url:     event.url ?? '',
  _slug:    slugify(event.name),
}}>
  function pad(n) { return String(n).padStart(2, '0'); }

  function toIcalDate(iso) {
    const d = new Date(iso + 'T12:00:00Z');
    return `${d.getUTCFullYear()}${pad(d.getUTCMonth() + 1)}${pad(d.getUTCDate())}`;
  }

  function nextDay(iso) {
    const d = new Date(iso + 'T12:00:00Z');
    d.setUTCDate(d.getUTCDate() + 1);
    return `${d.getUTCFullYear()}${pad(d.getUTCMonth() + 1)}${pad(d.getUTCDate())}`;
  }

  function fold(line) {
    if (line.length <= 75) return line;
    const out = [line.slice(0, 75)];
    let i = 75;
    while (i < line.length) { out.push(' ' + line.slice(i, i + 74)); i += 74; }
    return out.join('\r\n');
  }

  document.getElementById('add-to-cal').addEventListener('click', () => {
    const dtStart = toIcalDate(_date);
    const dtEnd   = nextDay(_dateTo ?? _date);

    const lines = [
      'BEGIN:VCALENDAR',
      'VERSION:2.0',
      'PRODID:-//SwingFestivals//EN',
      'CALSCALE:GREGORIAN',
      'BEGIN:VEVENT',
      `DTSTART;VALUE=DATE:${dtStart}`,
      `DTEND;VALUE=DATE:${dtEnd}`,
      fold(`SUMMARY:${_name}`),
      fold(`LOCATION:${_city}, ${_country}`),
      _desc ? fold(`DESCRIPTION:${_desc.replace(/[\r\n]+/g, ' ').replace(/,/g, '\\,')}`) : null,
      _url  ? `URL:${_url}` : null,
      'END:VEVENT',
      'END:VCALENDAR',
    ].filter(l => l !== null).join('\r\n');

    const blob = new Blob([lines], { type: 'text/calendar;charset=utf-8' });
    const a = Object.assign(document.createElement('a'), {
      href:     URL.createObjectURL(blob),
      download: `${_slug}.ics`,
    });
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(a.href);
  });
</script>

<style>
  .festival-page { padding-top: 66px; }

  /* ── Hero ── */
  .fhero {
    position: relative; overflow: hidden;
    padding: 60px 5vw 70px; min-height: 60vh;
    display: flex; flex-direction: column; justify-content: flex-end;
    background: radial-gradient(ellipse 80% 60% at 50% 100%, rgba(201,168,76,.08) 0%, transparent 70%), var(--dark);
  }
  /* Capas del hero (de atrás a adelante):
     z-index 0 → imagen de fondo
     z-index 1 → overlay oscuro para legibilidad
     z-index 2 → glow decorativo
     z-index 3 → contenido de texto */
  .fhero-img {
    position: absolute; inset: 0; width: 100%; height: 100%;
    object-fit: cover; object-position: center;
    opacity: .55; pointer-events: none; z-index: 0;
  }
  .fhero-overlay {
    position: absolute; inset: 0; pointer-events: none; z-index: 1;
    background: linear-gradient(
      to bottom,
      rgba(10,7,4,.45) 0%,
      rgba(10,7,4,.70) 55%,
      rgba(10,7,4,.92) 100%
    );
  }
  .fhero-bg-glow {
    position: absolute; inset: 0; pointer-events: none; z-index: 2;
    background:
      radial-gradient(circle 500px at 20% 80%, rgba(201,168,76,.06) 0%, transparent 70%),
      radial-gradient(circle 400px at 80% 20%, rgba(58,154,134,.04) 0%, transparent 70%);
  }

  .back-link {
    display: inline-flex; align-items: center; gap: 6px;
    font-family: Arial, sans-serif; font-size: 10px;
    letter-spacing: .22em; text-transform: uppercase;
    color: var(--muted); transition: color .2s, transform .22s; margin-bottom: 2rem;
    position: relative; z-index: 3;
  }
  .back-link:hover { color: var(--gold); transform: translateX(-4px); }

  .fhero-badges {
    display: flex; gap: 8px; flex-wrap: wrap;
    margin-bottom: 1.2rem; position: relative; z-index: 3;
  }
  .badge-type {
    font-family: Arial, sans-serif; font-size: 9px;
    letter-spacing: .22em; text-transform: uppercase;
    padding: 4px 12px; border: 1px solid;
  }
  .badge-style {
    font-family: Arial, sans-serif; font-size: 9px;
    letter-spacing: .22em; text-transform: uppercase;
    padding: 4px 12px; border: 1px solid rgba(201,168,76,.3);
    color: var(--gold);
  }

  .fhero-name {
    font-family: Georgia, serif;
    font-size: clamp(2.2rem, 7vw, 5rem);
    color: var(--cream); line-height: 1.05;
    margin-bottom: 1.6rem; position: relative; z-index: 3;
  }

  .fhero-date {
    display: flex; align-items: center; gap: 14px;
    margin-bottom: 1rem; position: relative; z-index: 3;
  }
  .fhero-date-num {
    font-family: Georgia, serif; font-size: 4rem; color: var(--gold);
    line-height: 1;
  }
  .fhero-date-info { display: flex; flex-direction: column; }
  .fhero-month {
    font-family: Arial, sans-serif; font-size: 9px;
    letter-spacing: .3em; text-transform: uppercase; color: var(--muted);
  }
  .fhero-year {
    font-family: Georgia, serif; font-size: 1.4rem; color: var(--cream2);
  }

  .fhero-loc {
    display: flex; align-items: center; gap: 10px;
    font-family: Arial, sans-serif; font-size: 13px; color: var(--cream2);
    margin-bottom: 1.8rem; position: relative; z-index: 3;
  }
  .loc-icon { color: var(--gold); font-size: .8em; }
  .loc-sep  { color: var(--muted); }

  .fhero-actions {
    display: flex; gap: 12px; flex-wrap: wrap;
    position: relative; z-index: 3;
  }
  .btn-tickets {
    background: var(--gold); color: var(--dark);
    font-family: Arial, sans-serif; font-size: 10px;
    letter-spacing: .18em; text-transform: uppercase; font-weight: 700;
    padding: 12px 24px;
    transition: background .2s, transform .18s, box-shadow .2s;
  }
  .btn-tickets:hover {
    background: var(--gold-l);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(201,168,76,.35);
  }
  .btn-tickets:active { transform: translateY(0); box-shadow: none; }
  .btn-web {
    border: 1px solid rgba(255,255,255,.15); color: var(--muted);
    font-family: Arial, sans-serif; font-size: 10px;
    letter-spacing: .18em; text-transform: uppercase;
    padding: 12px 24px; transition: color .2s, border-color .2s, transform .18s;
  }
  .btn-web:hover { color: var(--cream); border-color: rgba(255,255,255,.3); transform: translateY(-2px); }
  .btn-web:active { transform: translateY(0); }
  .btn-cal {
    display: inline-flex; align-items: center; gap: 7px;
    border: 1px solid rgba(255,255,255,.15); color: var(--muted);
    font-family: Arial, sans-serif; font-size: 10px;
    letter-spacing: .18em; text-transform: uppercase;
    padding: 12px 20px; background: transparent; cursor: pointer;
    transition: color .2s, border-color .2s, transform .18s;
  }
  .btn-cal:hover { color: var(--cream); border-color: rgba(255,255,255,.3); transform: translateY(-2px); }
  .btn-cal:active { transform: translateY(0); }

  /* ── Descripción ── */
  .fdesc { background: var(--dark2); padding: 56px 5vw; }
  .fdesc-inner { max-width: 740px; margin: 0 auto; }
  .sec-eyebrow {
    display: flex; align-items: center; gap: 10px;
    letter-spacing: .36em; font-size: 9.5px; text-transform: uppercase;
    color: var(--gold); font-weight: 700; margin-bottom: .8rem;
    font-family: Arial, sans-serif;
  }
  .sec-eyebrow::after { content: ''; width: 26px; height: 1px; background: var(--gold); opacity: .4; }
  .fdesc-text {
    font-family: Georgia, serif; font-size: 1.08rem;
