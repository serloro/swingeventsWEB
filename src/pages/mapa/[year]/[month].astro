---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Nav        from '../../../components/Nav.astro';
import Footer     from '../../../components/Footer.astro';
import { getEvents, slugify } from '../../../lib/directus.js';
import type { Event } from '../../../types/index.js';

const MONTH_NAMES = ['January','February','March','April','May','June',
                     'July','August','September','October','November','December'];

export async function getStaticPaths() {
  const events = await getEvents();
  const byYM = new Map<string, Event[]>();
  for (const e of events) {
    const d   = new Date(e.date);
    const key = `${d.getFullYear()}/${String(d.getMonth() + 1).padStart(2, '0')}`;
    if (!byYM.has(key)) byYM.set(key, []);
    byYM.get(key)!.push(e);
  }
  return [...byYM.entries()].map(([key, evs]) => {
    const [year, month] = key.split('/');
    return { params: { year, month }, props: { events: evs } };
  });
}

interface Props { events: Event[] }
const { events } = Astro.props;
const { year, month } = Astro.params;

const monthName = MONTH_NAMES[Number(month) - 1];

function fmtRange(from: string, to?: string) {
  const a = new Date(from);
  if (!to) return `${a.getDate()} ${MONTH_NAMES[a.getMonth()]}`;
  const b = new Date(to);
  if (a.getMonth() === b.getMonth())
    return `${a.getDate()}–${b.getDate()} ${MONTH_NAMES[a.getMonth()]}`;
  return `${a.getDate()} ${MONTH_NAMES[a.getMonth()].slice(0,3)} – ${b.getDate()} ${MONTH_NAMES[b.getMonth()].slice(0,3)}`;
}

const mapEvents = events.filter(e => e.map);

const markers = mapEvents.map(e => ({
  lat:     e.map!.lat,
  lng:     e.map!.lng,
  name:    e.name,
  city:    e.city,
  country: e.country,
  dates:   fmtRange(e.date, e.dateTo),
  url:     `/${slugify(e.name)}/${new Date(e.date).getFullYear()}/`,
}));

const markersJson = JSON.stringify(markers);
const hasMarkers  = markers.length > 0;
---

<BaseLayout
  title={`Festival map · ${monthName} ${year} — Swing Festivals`}
  description={`Map of swing festivals for ${monthName} ${year}`}
>
  <Nav />

  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

  <main class="map-page">

    <header class="map-hdr">
      <div class="map-hdr-inner">
        <a href="/#eventos" class="back-link">← Event calendar</a>
        <div class="mh-row">
          <div>
            <div class="mh-eyebrow">Festival map</div>
            <h1 class="mh-title">{monthName} <span class="mh-year">{year}</span></h1>
          </div>
          <p class="mh-count">
            {hasMarkers
              ? `${markers.length} festival${markers.length !== 1 ? 's' : ''} located`
              : 'No location data for this month'}
          </p>
        </div>
      </div>
    </header>

    {hasMarkers
      ? <div id="map" class="map-container"></div>
      : <div class="map-empty">
          <div class="map-empty-inner">
            <span class="map-empty-icon">🗺</span>
            <p>No festivals with location data for {monthName} {year}.</p>
            <a href="/#eventos" class="map-empty-back">← Back to calendar</a>
          </div>
        </div>
    }

  </main>

  <Footer />
</BaseLayout>

<script type="application/json" id="map-markers" set:html={markersJson}></script>

<script is:inline>
  (function () {
    function doInit() {
      var el = document.getElementById('map');
      if (!el || el._leaflet_id) return;

      var raw = document.getElementById('map-markers');
      if (!raw) return;
      var data = JSON.parse(raw.textContent || '[]');
      if (!data.length) return;

      var map = L.map('map');

      L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> &copy; <a href="https://carto.com/attributions">CARTO</a>',
        maxZoom: 19,
      }).addTo(map);

      var icon = L.divIcon({
        className: 'sf-map-icon',
        html: '<div class="sf-pin"></div>',
        iconSize:    [22, 22],
        iconAnchor:  [11, 22],
        popupAnchor: [0, -24],
      });

      var bounds = [];
      data.forEach(function (m) {
        L.marker([m.lat, m.lng], { icon: icon })
          .bindPopup(
            '<div class="sf-pop">' +
              '<div class="sf-pop-name">' + m.name + '</div>' +
              '<div class="sf-pop-meta">📍 ' + m.city + ', ' + m.country + '</div>' +
              '<div class="sf-pop-meta">📅 ' + m.dates + '</div>' +
              '<a href="' + m.url + '" class="sf-pop-btn">View festival →</a>' +
            '</div>',
            { maxWidth: 520, className: 'sf-leaflet-popup' }
          )
          .addTo(map);
        bounds.push([m.lat, m.lng]);
      });

      bounds.length === 1
        ? map.setView(bounds[0], 9)
        : map.fitBounds(bounds, { padding: [50, 50] });
    }

    function loadAndInit() {
      if (window.L) { doInit(); return; }
      var s = document.createElement('script');
      s.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
      s.onload = doInit;
      document.head.appendChild(s);
    }

    document.addEventListener('astro:page-load', loadAndInit);
    loadAndInit();
  })();
</script>

<style>
  .map-page { background: var(--dark); min-height: 100vh; display: flex; flex-direction: column; }

  /* ── Header ── */
  .map-hdr {
    background: var(--dark2); border-bottom: 1px solid var(--border-sm);
    padding: 90px 5vw 28px;
  }
  .map-hdr-inner { max-width: 1020px; margin: 0 auto; }

  .back-link {
    display: inline-block; margin-bottom: 18px;
    font-family: Arial, sans-serif; font-size: 10px; letter-spacing: .18em;
    text-transform: uppercase; color: var(--muted); transition: color .2s;
  }
  .back-link:hover { color: var(--gold); }

  .mh-row    { display: flex; align-items: flex-end; justify-content: space-between; flex-wrap: wrap; gap: 10px; }
  .mh-eyebrow {
    font-family: Arial, sans-serif; font-size: 9.5px; letter-spacing: .36em;
    text-transform: uppercase; color: var(--gold); font-weight: 700; margin-bottom: .3rem;
  }
  .mh-title { font-family: Georgia, serif; font-size: clamp(1.6rem,3vw,2.4rem); color: var(--cream); line-height: 1.1; }
  .mh-year  { color: var(--gold); }
  .mh-count { font-family: Arial, sans-serif; font-size: 11px; color: var(--muted); letter-spacing: .1em; }

  /* ── Map ── */
  .map-container {
    flex: 1;
    min-height: 500px;
    height: calc(100vh - 290px);
  }

  /* ── Empty state ── */
  .map-empty       { flex: 1; display: flex; align-items: center; justify-content: center; min-height: 400px; }
  .map-empty-inner { text-align: center; }
  .map-empty-icon  { font-size: 3rem; margin-bottom: 1rem; display: block; }
  .map-empty-inner p {
    font-family: Arial, sans-serif; font-size: .9rem; color: var(--muted);
    margin-bottom: 1.8rem;
  }
  .map-empty-back {
    font-family: Arial, sans-serif; font-size: 10px; letter-spacing: .18em;
    text-transform: uppercase; color: var(--gold); border: 1px solid rgba(201,168,76,.4);
    padding: 9px 18px; transition: background .2s, border-color .2s;
  }
  .map-empty-back:hover { background: rgba(201,168,76,.08); border-color: var(--gold); }
</style>

<style is:global>
  /* ── Custom marker ── */
  .sf-map-icon { background: none !important; border: none !important; }
  .sf-pin {
    width: 18px; height: 18px;
    background: #C9A84C;
    border-radius: 50% 50% 50% 0;
    transform: rotate(-45deg);
    border: 2px solid rgba(255,255,255,.35);
    box-shadow: 0 2px 8px rgba(0,0,0,.55);
    transition: transform .2s;
  }

  /* ── Leaflet popup overrides ── */
  .sf-leaflet-popup .leaflet-popup-content-wrapper {
    background: #1A1510;
    border: 1px solid rgba(201,168,76,.22);
    border-radius: 0;
    box-shadow: 0 6px 28px rgba(0,0,0,.65);
    padding: 0;
  }
  .sf-leaflet-popup .leaflet-popup-content { margin: 0; width: auto !important; }
  .sf-leaflet-popup .leaflet-popup-tip-container { display: none; }
  .sf-leaflet-popup .leaflet-popup-close-button {
    color: #8A7A5A !important; top: 10px !important; right: 14px !important;
    font-size: 22px !important; width: 24px !important; height: 24px !important;
  }

  .sf-pop { padding: 24px 28px; min-width: 280px; }
  .sf-pop-name {
    font-family: Georgia, serif; font-size: 1.35rem; color: #F0E6C8;
    margin-bottom: 12px; line-height: 1.3; padding-right: 22px;
  }
  .sf-pop-meta {
    font-family: Arial, sans-serif; font-size: 14px; color: #8A7A5A;
    margin-bottom: 6px;
  }
  .sf-pop-btn {
    display: inline-block; margin-top: 16px;
    font-family: Arial, sans-serif; font-size: 11px; letter-spacing: .16em;
    text-transform: uppercase; color: #C9A84C;
    border: 1px solid rgba(201,168,76,.35); padding: 9px 22px;
    transition: background .2s, border-color .2s;
  }
  .sf-pop-btn:hover { background: rgba(201,168,76,.1); border-color: #C9A84C; }

  /* ── Leaflet controls dark theme ── */
  .leaflet-control-attribution {
    background: rgba(10,7,4,.72) !important;
    color: rgba(138,122,90,.8) !important;
    font-size: 9px !important;
  }
  .leaflet-control-attribution a { color: #C9A84C !important; }
  .leaflet-control-zoom a {
    background: #1A1510 !important; color: #C9A84C !important;
    border-color: rgba(201,168,76,.2) !important;
  }
  .leaflet-control-zoom a:hover { background: rgba(201,168,76,.1) !important; }
</style>
