# ── Directus ──────────────────────────────────────────
# URL de tu instancia Directus (sin barra final)
DIRECTUS_URL=https://tu-directus.com

# Token estático de solo lectura (Settings → Access Tokens)
DIRECTUS_TOKEN=your_static_token_here

# Si se define como "true" se usan los datos mock aunque haya Directus
USE_MOCK_DATA=false
